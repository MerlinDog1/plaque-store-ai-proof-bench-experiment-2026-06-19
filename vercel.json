{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.instaplaque.co.uk"
        }
      ],
      "destination": "https://instaplaque.co.uk/:path*",
      "permanent": true
    },
    {
      "source": "/etchmaster",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/design",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/etchmaster/(.*)",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/house-plaques",
      "destination": "/custom-plaques",
      "permanent": true
    },
    {
      "source": "/brass-house-signs",
      "destination": "/brass-plaques",
      "permanent": true
    },
    {
      "source": "/stainless-steel-signs",
      "destination": "/stainless-steel-plaques",
      "permanent": true
    },
    {
      "source": "/returns-and-cancellations",
      "destination": "/returns-cancellations",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/checkout",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/order-confirmed",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.mjs"
    }
  ]
}
