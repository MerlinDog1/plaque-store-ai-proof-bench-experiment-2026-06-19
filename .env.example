# Required by server.mjs for AI-assisted composition and realistic preview generation.
GEMINI_API_KEY=
# Production/serverless deployments stay disabled unless this is explicitly true.
GEMINI_PUBLIC_PROXY_ENABLED=
# Weighted units per client IP per warm server/serverless instance each minute.
# Text operations cost 1 unit; image cost varies by model and resolution. Also
# set a hard project quota because serverless instances cannot share memory.
GEMINI_RATE_LIMIT_UNITS_PER_MINUTE=20

# Supabase server-side access. Never expose the service role key in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional browser-safe Supabase config for future direct public reads.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe Checkout. Keep secret/webhook values server-side only.
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin/order protection.
ADMIN_PASSWORD=
ADMIN_ACCESS_TOKEN=
ADMIN_AUTH_SECRET=

# Central storefront intake. Comma-separated source:key pairs, e.g.
# instaplaque:sk_live_internal_...,memorial-site:sk_live_internal_...
STOREFRONT_INGEST_KEYS=

# Resend order emails.
RESEND_API_KEY=
ORDER_EMAIL_FROM=
ORDER_ADMIN_EMAIL=
PUBLIC_SITE_URL=

# Local development only. Neither flag is honoured in NODE_ENV=production or on Vercel.
# Keep both unset in every deployed environment.
ALLOW_LOCAL_ORDER_JSON_STORE=false
ALLOW_LOCAL_CHECKOUT_ORIGIN=false
